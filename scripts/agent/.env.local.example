# DriveCodex crawl agent — local secrets (TEMPLATE)
#
# Copy this file to ".env.local" in the same folder and fill in the values.
# ".env.local" is git-ignored and must NEVER be committed.
#
# Once filled, the agent operates Supabase autonomously:
#   - run-agent-batch.ps1 loads it automatically (scheduled runs)
#   - manual runs:  node --experimental-sqlite --env-file=scripts/agent/.env.local scripts/agent/orchestrator.mjs ...
#   - migrations:   the agent can run `supabase db push` non-interactively
#
# Format: KEY=value  (no "export", no quotes needed; '#' starts a comment)

# Supabase project (public — already correct for production)
SUPABASE_URL=https://nmvjthfezyjcwuzphiuu.supabase.co

# service_role API key — Dashboard → Project Settings → API → "service_role" (secret).
# Enables the online crawl_forums registry + case import + crosscheck.
SUPABASE_SERVICE_KEY=

# Database password — Dashboard → Project Settings → Database → "Database password"
# (reset it there if unknown). Lets `supabase db push` apply migrations without prompting.
SUPABASE_DB_PASSWORD=

# DeepSeek API key — used for the independent verification step (cross-vendor auditor).
DEEPSEEK_API_KEY=
